    "@mui/material": "^7.1.2",
    "@reduxjs/toolkit": "^1.9.5",
    "@tanstack/react-query": "^5.100.10",
    "clsx": "^2.1.1",
    "firebase": "^10.5.2",
    "framer-motion": "^12.38.0",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.76.0",
